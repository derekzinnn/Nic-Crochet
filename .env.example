# ─────────────────────────────────────────────────────────────
# Nic Crochet — environment variables
# Copy to `.env` and fill in. See SETUP.md for how to obtain each value.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ──
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma for migrations / db push.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Storage (product photos) ──
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
# Service-role key — SERVER ONLY, never expose to the client. Used for uploads.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Public bucket name for product photos.
SUPABASE_STORAGE_BUCKET="product-photos"

# ── Admin auth (single artisan account) ──
ADMIN_USERNAME="nic"
# bcrypt hash of the admin password. Generate with: npm run admin:hash -- "yourpassword"
ADMIN_PASSWORD_HASH="<bcrypt-hash>"
# Secret for signing the session cookie (JWT). Use a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="<long-random-string>"

# ── Public contact details (PLACEHOLDERS — swap before launch) ──
# WhatsApp number in international format, digits only (country + DDD + number).
NEXT_PUBLIC_WHATSAPP_NUMBER="5500000000000"
NEXT_PUBLIC_INSTAGRAM_HANDLE="nic.crochet"
NEXT_PUBLIC_CONTACT_EMAIL="contato@niccrochet.com"

# ── Site ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
